CHOSENPASSWORD=changeme
SETALIAS=yournodealias
SETHOST=yournodeFQDM
THUB_HOST=thunderhub.yournodeFQDM
LND_HOST=lnd.yournodeFQDM
LETSENCRYPT_EMAIL=you@example.com

# Network privacy mode for LND (set by ./scripts/install, editable here):
#   clearnet -> public IP + domain only (default)
#   hybrid   -> clearnet + Tor v3 onion
#   tor      -> Tor onion only, public IP not advertised
TOR_MODE=clearnet
# Starts the tor container automatically; keep in sync with TOR_MODE.
# Empty for clearnet, "tor" for hybrid/tor.
COMPOSE_PROFILES=
